# Required for browser Realtime sessions and realtime evals.
OPENAI_API_KEY=

# Optional. Defaults to gpt-realtime-2.
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Optional. Browser Realtime input noise reduction.
# Allowed: far_field, near_field, off, none, disabled.
MEALPLAN_REALTIME_NOISE_REDUCTION=far_field

# Optional. Sent as OpenAI-Safety-Identifier for browser Realtime calls.
MEALPLAN_REALTIME_SAFETY_IDENTIFIER=mealplan-voiceops-local-demo

# Optional. Required only for the manual /api/realtime/control debug route.
MEALPLAN_REALTIME_CONTROL_TOKEN=

# Optional. Set either value to 1, true, yes, or on to disable tracing.
OPENAI_REALTIME_DISABLE_TRACING=0
OPENAI_AGENTS_DISABLE_TRACING=0
